# ==============================================
# ShopSphere - Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to Git.

# --- Database ---
DB_URL=jdbc:mysql://localhost:3307/ShopSphereDB
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
MYSQL_ROOT_PASSWORD=your_root_password

# --- Gmail SMTP ---
# 1. Create a Gmail: e.g. shopsphere.notify@gmail.com
# 2. Enable 2FA on the account
# 3. Google Account → Security → App Passwords → generate for "Mail"
# 4. Paste the 16-char app password below (no spaces)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=shopsphere.notify@gmail.com
MAIL_PASSWORD=your_16_char_gmail_app_password

# --- JWT ---
# Generate: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- Frontend ---
FRONTEND_ACTIVATION_URL=http://localhost:4200/activate-account

# --- Stripe ---
# Get both keys from https://dashboard.stripe.com/apikeys
# Secret key: used by backend only, never expose to frontend
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Publishable key: safe to use in frontend (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
